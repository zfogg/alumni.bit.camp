{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "outDir": ".",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": false,
    "strict": true,
    "moduleResolution": "bundler",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["api/**/*.ts", "lib/**/*.ts"],
  "exclude": ["src", "node_modules", "dist"]
}
